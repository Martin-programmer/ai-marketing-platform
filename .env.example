# ─────────────────────────────────────────────────────────
# AI Marketing Platform — Local Development Environment
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=amp
POSTGRES_PASSWORD=amp
POSTGRES_DB=amp
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Backend ───────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# Spring Datasource (override for non-Docker dev)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/amp
SPRING_DATASOURCE_USERNAME=amp
SPRING_DATASOURCE_PASSWORD=amp

# ── Frontend ──────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080

# ── Dev Auth Headers (used by DevAuthFilter in local profile) ──
# These are sent as HTTP headers when testing the API:
# X-Agency-Id:  <agency-uuid>
# X-User-Id:    <user-uuid>
# X-User-Role:  ADMIN

# ── AWS (for Terraform / CD — not needed for local dev) ──
# AWS_ACCOUNT_ID=123456789012
# AWS_REGION=eu-central-1
# AWS_DEPLOY_ROLE_ARN=arn:aws:iam::123456789012:role/github-deploy

# ── Mailpit (local email testing) ────────────────────────
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
